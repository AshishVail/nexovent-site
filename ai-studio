<!DOCTYPE html>
<html lang="hi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nexovent AI Studio | Pro Prompt Lab</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    <link rel="manifest" href="manifest.json">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #05070a; color: white; transition: background 0.8s ease; }
        .glass-effect { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(15px); border: 1px solid rgba(255, 255, 255, 0.08); }
        .active-btn { background: #2563eb !important; border-color: #3b82f6 !important; box-shadow: 0 0 15px rgba(59, 130, 246, 0.5); }
        #generatedText::after { content: '|'; animation: blink 0.7s infinite; }
        @keyframes blink { 50% { opacity: 0; } }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(59, 130, 246, 0.3); border-radius: 10px; }
    </style>
</head>
<body class="min-h-screen bg-fixed bg-cover bg-center">
    <div class="flex h-screen overflow-hidden">
        <aside class="w-64 glass-effect p-6 hidden md:flex flex-col border-r border-white/10">
            <div class="text-2xl font-800 mb-10 tracking-tighter text-blue-500">NEXOVENT<span class="text-white">.AI</span></div>
            <nav class="space-y-4 flex-1">
                <button class="w-full flex items-center space-x-3 p-3 rounded-xl bg-blue-600/10 text-blue-400 border border-blue-600/20"><span>🚀</span> <span>Prompt Engine</span></button>
                <div class="mt-10 pt-6 border-t border-white/10">
                    <span class="text-[10px] text-gray-500 uppercase tracking-widest">Recent History</span>
                    <div id="historyContainer" class="mt-4 space-y-3 overflow-y-auto max-h-60 custom-scrollbar"></div>
                </div>
            </nav>
            <div class="p-4 glass-effect rounded-xl text-[10px] text-gray-500">Status: <span class="text-green-500">System Ready</span></div>
        </aside>

        <main class="flex-1 overflow-y-auto p-4 md:p-10">
            <div class="max-w-5xl mx-auto">
                <header class="mb-10 flex justify-between items-center">
                    <div>
                        <h1 class="text-4xl font-800">AI Prompt Studio <span class="text-sm bg-blue-600 px-2 py-0.5 rounded ml-2">PRO</span></h1>
                        <p class="text-gray-400 mt-2">Create cinematic prompts for Midjourney & DALL-E.</p>
                    </div>
                </header>

                <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
                    <div class="lg:col-span-4 space-y-6">
                        <div class="glass-effect p-6 rounded-3xl space-y-6">
                            <div>
                                <label class="text-[10px] font-bold text-gray-500 uppercase mb-3 block">Art Style</label>
                                <div class="grid grid-cols-2 gap-2">
                                    <button onclick="setStyle('Cinematic', this)" class="style-btn p-3 border border-white/10 rounded-xl text-xs active-btn">🎬 Cinematic</button>
                                    <button onclick="setStyle('Cyberpunk', this)" class="style-btn p-3 border border-white/10 rounded-xl text-xs">🌃 Cyberpunk</button>
                                </div>
                            </div>
                            <div>
                                <label class="text-[10px] font-bold text-gray-500 uppercase mb-3 block">Aspect Ratio</label>
                                <div class="grid grid-cols-3 gap-2">
                                    <button onclick="setRatio('1:1', this)" class="ratio-btn p-3 border border-white/10 rounded-xl text-xs active-btn">1:1</button>
                                    <button onclick="setRatio('16:9', this)" class="ratio-btn p-3 border border-white/10 rounded-xl text-xs">16:9</button>
                                    <button onclick="setRatio('9:16', this)" class="ratio-btn p-3 border border-white/10 rounded-xl text-xs">9:16</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="lg:col-span-8 space-y-6">
                        <div class="glass-effect p-8 rounded-3xl">
                            <textarea id="userInput" class="w-full h-40 bg-transparent text-2xl font-light placeholder-gray-700 outline-none resize-none" placeholder="Describe your vision..."></textarea>
                            <div class="flex flex-col md:flex-row justify-between items-center mt-6 pt-6 border-t border-white/10 gap-4">
                                <div class="cf-turnstile" data-sitekey="0x4AAAAAAAC8Q1xRQMVIesdD4" data-theme="dark"></div>
                                <button id="genBtn" onclick="generateProPrompt()" class="bg-blue-600 hover:bg-blue-700 px-10 py-4 rounded-2xl font-bold transition transform hover:scale-105">Generate Masterpiece</button>
                            </div>
                        </div>

                        <div id="resultBox" class="hidden glass-effect p-8 rounded-3xl border-l-4 border-blue-500 animate-pulse-once">
                            <div class="flex justify-between items-center mb-4">
                                <span class="text-blue-400 text-[10px] font-black uppercase">Result</span>
                                <button onclick="copyText()" class="text-[10px] bg-blue-600/20 text-blue-400 px-4 py-2 rounded-full hover:bg-blue-600 hover:text-white">COPY</button>
                            </div>
                            <p id="generatedText" class="text-xl text-gray-200 leading-relaxed italic"></p>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
    <script src="script.js"></script>
</body>
</html>
