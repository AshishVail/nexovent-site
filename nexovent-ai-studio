function saveToHistory(prompt) {
    let history = JSON.parse(localStorage.getItem('nexovent_history') || "[]");
    history.unshift({
        text: prompt,
        date: new Date().toLocaleTimeString(),
        style: activeStyle
    });
    // Keep only last 5 items
    history = history.slice(0, 5);
    localStorage.setItem('nexovent_history', JSON.stringify(history));
    console.log("Prompt saved to local history.");
}

