// 1. Style & Ratio Selection Logic
function setStyle(style, btn) {
    activeStyle = style;
    document.querySelectorAll('.style-btn').forEach(b => b.classList.remove('active-btn'));
    btn.classList.add('active-btn');
    playSoftClick();
}

function setRatio(ratio, btn) {
    activeRatio = ratio;
    document.querySelectorAll('.ratio-btn').forEach(b => b.classList.remove('active-btn'));
    btn.classList.add('active-btn');
    playSoftClick();
}

// 2. Human Typing Effect
function typeWriter(text, elementId) {
    const element = document.getElementById(elementId);
    element.innerHTML = "";
    let i = 0;
    const speed = 15; // Typing speed in ms

    function type() {
        if (i < text.length) {
            element.innerHTML += text.charAt(i);
            i++;
            setTimeout(type, speed);
        }
    }
    type();
}

// 3. Pexels Dynamic Background Update
async function updateBackground(query) {
    try {
        const response = await fetch(`https://api.pexels.com/v1/search?query=${query}&per_page=1`, {
            headers: { Authorization: CONFIG.PEXELS_KEY }
        });
        const data = await response.json();
        if (data.photos && data.photos.length > 0) {
            const imgUrl = data.photos[0].src.large2x;
            document.body.style.backgroundImage = `linear-gradient(rgba(5,7,10,0.8), rgba(5,7,10,0.95)), url('${imgUrl}')`;
        }
    } catch (error) {
        console.error("Background sync failed");
    }
}

// 4. Main Generation Engine (Gemini)
async function generateProPrompt() {
    const input = document.getElementById('userInput').value;
    const model = document.getElementById('modelSelect').value;
    const btn = document.getElementById('genBtn');
    
    // Turnstile Check
    const turnstileToken = document.querySelector('[name="cf-turnstile-response"]').value;

    if (!input) {
        alert("Please describe your vision first!");
        return;
    }
    if (!turnstileToken) {
        alert("Please complete the security check!");
        return;
    }

    // UI Feedback
    btn.disabled = true;
    btn.innerHTML = `<span class="animate-spin inline-block mr-2">⚙️</span> Processing...`;
    updateBackground(input);

    // Expert Instruction for Gemini
    const systemInstruction = `As the Nexovent PRO AI, transform this idea: "${input}" into a massive, detailed image prompt. 
    Target Model: ${model}. Style: ${activeStyle}. Ratio: ${activeRatio}. 
    Details to include: 8k resolution, cinematic lighting, volumetric fog, specific lens (35mm f/1.8), and rich textures. 
    Output format: Just the final prompt, no extra talk.`;

    try {
        const res = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${CONFIG.GEMINI_KEY}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ contents: [{ parts: [{ text: systemInstruction }] }] })
        });

        const data = await res.json();
        const finalPrompt = data.candidates[0].content.parts[0].text;

        // Display Result
        const resultBox = document.getElementById('resultBox');
        resultBox.classList.remove('hidden');
        typeWriter(finalPrompt, 'generatedText');
        
        // Success Feedback
        if (window.navigator.vibrate) window.navigator.vibrate([100, 50, 100]);

    } catch (err) {
        alert("System error. Check connection or API limit.");
    } finally {
        btn.disabled = false;
        btn.innerText = "Generate Masterpiece";
    }
}

