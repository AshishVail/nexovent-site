// 9. History Management System
function updateHistoryUI() {
    const container = document.getElementById('historyContainer');
    const history = JSON.parse(localStorage.getItem('nexovent_history') || "[]");

    if (history.length === 0) {
        container.innerHTML = `<p class="text-[11px] text-gray-600 italic">No history yet...</p>`;
        return;
    }

    container.innerHTML = history.map((item, index) => `
        <div class="p-3 bg-white/5 rounded-xl border border-white/5 hover:border-blue-500/50 transition cursor-pointer group" onclick="useHistoryItem(${index})">
            <div class="flex justify-between items-center mb-1">
                <span class="text-[9px] text-blue-400 font-bold">${item.style}</span>
                <span class="text-[8px] text-gray-600">${item.date}</span>
            </div>
            <p class="text-[10px] text-gray-400 truncate">${item.text}</p>
        </div>
    `).join('');
}

function useHistoryItem(index) {
    const history = JSON.parse(localStorage.getItem('nexovent_history') || "[]");
    const item = history[index];
    
    // वापस बॉक्स में डालना और दिखाना
    const resultBox = document.getElementById('resultBox');
    resultBox.classList.remove('hidden');
    document.getElementById('generatedText').innerText = item.text;
    
    // विजुअल फीडबैक
    if (window.navigator.vibrate) window.navigator.vibrate(20);
}

function clearHistory() {
    if(confirm("क्या आप सारी हिस्ट्री डिलीट करना चाहते हैं?")) {
        localStorage.removeItem('nexovent_history');
        updateHistoryUI();
    }
}

