// 7. Advanced Share Feature
async function sharePrompt() {
    const text = document.getElementById('generatedText').innerText;
    if (!text) return;

    if (navigator.share) {
        try {
            await navigator.share({
                title: 'Nexovent AI Prompt',
                text: text,
                url: window.location.href,
            });
        } catch (err) {
            console.log("Share failed or cancelled");
        }
    } else {
        // Fallback: Copy to clipboard if share not supported
        copyText();
        alert("Share not supported. Prompt copied instead!");
    }
}

