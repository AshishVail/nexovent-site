<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#111827" />
  <meta name="description" content="Nexovent Instagram Viral Growth Suite — premium mobile-first tools for reels, captions, hashtags, bios, and planning." />
  <title>Nexovent - Insta Growth Suite</title>

  <!-- Tailwind (CDN) -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    // Tailwind config (mobile-app feel + glass)
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['ui-sans-serif','system-ui','-apple-system','Segoe UI','Roboto','Helvetica','Arial'],
          },
          boxShadow: {
            glass: '0 20px 60px rgba(0,0,0,.35)',
            soft: '0 10px 25px rgba(0,0,0,.25)'
          }
        }
      }
    }
  </script>

  <style>
    /* ========= App Background + Glass Theme ========= */
    :root{
      --grad-1:#833ab4;
      --grad-2:#fd1d1d;
      --grad-3:#fcb045;
    }
    body{
      background: linear-gradient(135deg, var(--grad-1), var(--grad-2), var(--grad-3));
      min-height: 100vh;
    }
    /* iOS safe area */
    .safe-top{ padding-top: max(env(safe-area-inset-top), 12px); }
    .safe-bot{ padding-bottom: max(env(safe-area-inset-bottom), 12px); }

    .glass{
      background: rgba(255,255,255,.14);
      border: 1px solid rgba(255,255,255,.22);
      box-shadow: 0 20px 60px rgba(0,0,0,.25);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
    }
    .glass-strong{
      background: rgba(17,24,39,.28);
      border: 1px solid rgba(255,255,255,.18);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
    }
    .chip{
      background: rgba(255,255,255,.12);
      border: 1px solid rgba(255,255,255,.18);
    }
    .tap{
      -webkit-tap-highlight-color: transparent;
    }
    /* Premium app micro-interactions */
    .press{
      transition: transform .12s ease, filter .12s ease, opacity .12s ease;
    }
    .press:active{ transform: scale(.99); filter: brightness(1.05); }

    /* nicer scrollbars on WebKit */
    .scrollbar::-webkit-scrollbar{ height: 10px; width: 10px; }
    .scrollbar::-webkit-scrollbar-thumb{ background: rgba(255,255,255,.25); border-radius: 999px; }
    .scrollbar::-webkit-scrollbar-track{ background: rgba(255,255,255,.08); border-radius: 999px; }

    /* Modal */
    .modal-backdrop{
      background: rgba(0,0,0,.55);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }

    /* Small helper: make inputs feel native */
    input, textarea, select{
      outline: none;
    }
  </style>
</head>

<body class="text-white font-sans antialiased">
  <!-- Sticky Glass Header -->
  <header class="sticky top-0 z-50 safe-top">
    <div class="mx-auto max-w-md px-4">
      <div class="glass rounded-2xl px-4 py-3 flex items-center justify-between gap-3">
        <div class="flex items-center gap-3 min-w-0">
          <div class="h-10 w-10 rounded-2xl glass-strong flex items-center justify-center shadow-soft">
            <span class="text-lg font-black">N</span>
          </div>
          <div class="min-w-0">
            <div class="text-sm font-semibold leading-tight truncate">Nexovent - Insta Growth Suite</div>
            <div class="text-xs text-white/80 leading-tight truncate">Glass tools to go viral (offline demo)</div>
          </div>
        </div>
        <button id="btnHelp" class="tap press chip rounded-xl px-3 py-2 text-xs font-semibold">
          Help
        </button>
      </div>
    </div>
  </header>

  <!-- App Shell -->
  <main class="mx-auto max-w-md px-4 pb-24 safe-bot">
    <!-- Top quick actions -->
    <section class="mt-4">
      <div class="glass rounded-2xl p-4">
        <div class="flex items-start justify-between gap-3">
          <div>
            <h1 class="text-base font-extrabold tracking-tight">Instagram Viral Growth Suite</h1>
            <p class="text-xs text-white/80 mt-1">
              10 premium mini-tools in one mobile app UI. Everything runs in your browser.
            </p>
          </div>
          <div class="flex flex-col items-end gap-2">
            <span class="chip rounded-full px-3 py-1 text-[11px] font-semibold">Single-file</span>
            <span class="chip rounded-full px-3 py-1 text-[11px] font-semibold">Vanilla JS</span>
          </div>
        </div>

        <div class="mt-4 grid grid-cols-2 gap-3">
          <button class="tap press chip rounded-2xl p-3 text-left" data-jump="#toolScript">
            <div class="text-xs text-white/80">Start Here</div>
            <div class="font-bold text-sm">Reel Script Writer</div>
          </button>
          <button class="tap press chip rounded-2xl p-3 text-left" data-jump="#toolPlanner">
            <div class="text-xs text-white/80">Plan</div>
            <div class="font-bold text-sm">7-Day Reel Planner</div>
          </button>
        </div>
      </div>
    </section>

    <!-- Tools Grid -->
    <section class="mt-4 space-y-4">

      <!-- 1) AI Reel Script & Hook Writer -->
      <article id="toolScript" class="glass rounded-2xl p-4">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-sm font-extrabold">1) AI Reel Script & Hook Writer</h2>
          <span class="chip rounded-full px-3 py-1 text-[11px] font-semibold">30 sec</span>
        </div>
        <p class="text-xs text-white/80 mt-1">
          Enter a topic. Generates a viral hook + a structured 30-second reel script.
        </p>

        <label class="block mt-3 text-xs font-semibold text-white/90">Topic</label>
        <input id="scriptTopic" class="mt-1 w-full glass-strong rounded-2xl px-4 py-3 text-sm placeholder:text-white/50"
               placeholder="e.g., How to grow on Instagram as a tech creator" />

        <div class="mt-3 flex gap-2">
          <button id="btnGenScript" class="tap press flex-1 rounded-2xl bg-white/20 hover:bg-white/25 px-4 py-3 text-sm font-bold">
            Generate Script
          </button>
          <button id="btnCopyScript" class="tap press chip rounded-2xl px-4 py-3 text-sm font-semibold">
            Copy
          </button>
        </div>

        <div class="mt-3 glass-strong rounded-2xl p-3">
          <div class="text-xs font-semibold text-white/80">Output</div>
          <pre id="scriptOut" class="mt-2 whitespace-pre-wrap text-sm leading-relaxed text-white/90"></pre>
        </div>
      </article>

      <!-- 2) Color Palette Extractor -->
      <article id="toolPalette" class="glass rounded-2xl p-4">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-sm font-extrabold">2) Color Palette Extractor</h2>
          <span class="chip rounded-full px-3 py-1 text-[11px] font-semibold">Image</span>
        </div>
        <p class="text-xs text-white/80 mt-1">
          Upload a photo to extract dominant colors (approx). Runs locally using Canvas.
        </p>

        <div class="mt-3 grid grid-cols-1 gap-3">
          <input id="paletteFile" type="file" accept="image/*"
                 class="block w-full text-xs file:mr-3 file:rounded-xl file:border-0 file:bg-white/20 file:text-white file:px-4 file:py-2 file:font-semibold file:tap file:press" />

          <div class="grid grid-cols-2 gap-3 items-start">
            <div class="glass-strong rounded-2xl p-3">
              <div class="text-xs font-semibold text-white/80">Preview</div>
              <canvas id="paletteCanvas" class="mt-2 w-full rounded-xl overflow-hidden"></canvas>
              <div class="mt-2 text-[11px] text-white/70">Tip: brighter photos extract better.</div>
            </div>

            <div class="glass-strong rounded-2xl p-3">
              <div class="flex items-center justify-between">
                <div class="text-xs font-semibold text-white/80">HEX Palette</div>
                <button id="btnCopyPalette" class="tap press chip rounded-xl px-3 py-2 text-xs font-semibold">Copy</button>
              </div>
              <div id="paletteSwatches" class="mt-2 grid grid-cols-2 gap-2"></div>
            </div>
          </div>
        </div>
      </article>

      <!-- 3) Insta-Font Styler -->
      <article id="toolFonts" class="glass rounded-2xl p-4">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-sm font-extrabold">3) Insta-Font Styler</h2>
          <span class="chip rounded-full px-3 py-1 text-[11px] font-semibold">10+ styles</span>
        </div>
        <p class="text-xs text-white/80 mt-1">
          Real-time text converter for bio. Copy the style you like.
        </p>

        <label class="block mt-3 text-xs font-semibold text-white/90">Text</label>
        <input id="fontInput" class="mt-1 w-full glass-strong rounded-2xl px-4 py-3 text-sm placeholder:text-white/50"
               placeholder="Type your bio line…" />

        <div class="mt-3 glass-strong rounded-2xl p-3">
          <div class="flex items-center justify-between">
            <div class="text-xs font-semibold text-white/80">Styles</div>
            <button id="btnCopyFirstFont" class="tap press chip rounded-xl px-3 py-2 text-xs font-semibold">Copy Top</button>
          </div>
          <div id="fontList" class="mt-2 space-y-2"></div>
        </div>
      </article>

      <!-- 4) AI Caption & Emoji Recommender -->
      <article id="toolCaption" class="glass rounded-2xl p-4">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-sm font-extrabold">4) AI Caption & Emoji Recommender</h2>
          <span class="chip rounded-full px-3 py-1 text-[11px] font-semibold">Caption</span>
        </div>
        <p class="text-xs text-white/80 mt-1">
          Describe the photo and get a pro caption with matching emojis + CTA.
        </p>

        <label class="block mt-3 text-xs font-semibold text-white/90">Photo Description</label>
        <textarea id="captionDesc" rows="3"
          class="mt-1 w-full glass-strong rounded-2xl px-4 py-3 text-sm placeholder:text-white/50"
          placeholder="e.g., Laptop on desk, coding at night, neon vibes"></textarea>

        <div class="mt-3 flex gap-2">
          <button id="btnGenCaption" class="tap press flex-1 rounded-2xl bg-white/20 hover:bg-white/25 px-4 py-3 text-sm font-bold">
            Generate Caption
          </button>
          <button id="btnCopyCaption" class="tap press chip rounded-2xl px-4 py-3 text-sm font-semibold">
            Copy
          </button>
        </div>

        <div class="mt-3 glass-strong rounded-2xl p-3">
          <div class="text-xs font-semibold text-white/80">Output</div>
          <div id="captionOut" class="mt-2 text-sm leading-relaxed text-white/90"></div>
        </div>
      </article>

      <!-- 5) Viral Hashtag Finder -->
      <article id="toolHashtags" class="glass rounded-2xl p-4">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-sm font-extrabold">5) Viral Hashtag Finder</h2>
          <span class="chip rounded-full px-3 py-1 text-[11px] font-semibold">Low/High</span>
        </div>
        <p class="text-xs text-white/80 mt-1">
          Choose a niche to generate mixed competition tags.
        </p>

        <div class="mt-3 grid grid-cols-2 gap-3">
          <div>
            <label class="text-xs font-semibold text-white/90">Niche</label>
            <select id="tagNiche" class="mt-1 w-full glass-strong rounded-2xl px-4 py-3 text-sm">
              <option value="tech">Tech</option>
              <option value="finance">Finance</option>
              <option value="lifestyle">Lifestyle</option>
            </select>
          </div>
          <div>
            <label class="text-xs font-semibold text-white/90">Total Tags</label>
            <select id="tagCount" class="mt-1 w-full glass-strong rounded-2xl px-4 py-3 text-sm">
              <option>10</option>
              <option selected>20</option>
              <option>30</option>
            </select>
          </div>
        </div>

        <div class="mt-3 flex gap-2">
          <button id="btnGenTags" class="tap press flex-1 rounded-2xl bg-white/20 hover:bg-white/25 px-4 py-3 text-sm font-bold">
            Generate Hashtags
          </button>
          <button id="btnCopyTags" class="tap press chip rounded-2xl px-4 py-3 text-sm font-semibold">
            Copy
          </button>
        </div>

        <div class="mt-3 grid grid-cols-1 gap-3">
          <div class="glass-strong rounded-2xl p-3">
            <div class="flex items-center justify-between">
              <div class="text-xs font-semibold text-white/80">Low Competition</div>
              <span class="text-[11px] text-white/70">More discoverable</span>
            </div>
            <div id="tagsLow" class="mt-2 flex flex-wrap gap-2"></div>
          </div>

          <div class="glass-strong rounded-2xl p-3">
            <div class="flex items-center justify-between">
              <div class="text-xs font-semibold text-white/80">High Competition</div>
              <span class="text-[11px] text-white/70">More reach</span>
            </div>
            <div id="tagsHigh" class="mt-2 flex flex-wrap gap-2"></div>
          </div>
        </div>
      </article>

      <!-- 6) Engagement Rate Calculator -->
      <article id="toolEngagement" class="glass rounded-2xl p-4">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-sm font-extrabold">6) Engagement Rate Calculator</h2>
          <span class="chip rounded-full px-3 py-1 text-[11px] font-semibold">Health</span>
        </div>
        <p class="text-xs text-white/80 mt-1">
          Enter Followers, Likes, Comments. Get ER% and a health score.
        </p>

        <div class="mt-3 grid grid-cols-3 gap-2">
          <div>
            <label class="text-xs font-semibold">Followers</label>
            <input id="erFollowers" inputmode="numeric" class="mt-1 w-full glass-strong rounded-2xl px-3 py-3 text-sm" placeholder="10k" />
          </div>
          <div>
            <label class="text-xs font-semibold">Likes</label>
            <input id="erLikes" inputmode="numeric" class="mt-1 w-full glass-strong rounded-2xl px-3 py-3 text-sm" placeholder="500" />
          </div>
          <div>
            <label class="text-xs font-semibold">Comments</label>
            <input id="erComments" inputmode="numeric" class="mt-1 w-full glass-strong rounded-2xl px-3 py-3 text-sm" placeholder="45" />
          </div>
        </div>

        <div class="mt-3 flex gap-2">
          <button id="btnCalcER" class="tap press flex-1 rounded-2xl bg-white/20 hover:bg-white/25 px-4 py-3 text-sm font-bold">
            Calculate
          </button>
          <button id="btnResetER" class="tap press chip rounded-2xl px-4 py-3 text-sm font-semibold">
            Reset
          </button>
        </div>

        <div class="mt-3 glass-strong rounded-2xl p-3">
          <div class="text-xs font-semibold text-white/80">Results</div>
          <div id="erOut" class="mt-2 text-sm text-white/90"></div>
        </div>
      </article>

      <!-- 7) Best Posting Time Finder -->
      <article id="toolTime" class="glass rounded-2xl p-4">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-sm font-extrabold">7) Best Posting Time Finder</h2>
          <span class="chip rounded-full px-3 py-1 text-[11px] font-semibold">Schedule</span>
        </div>
        <p class="text-xs text-white/80 mt-1">
          Choose your audience type for suggested best posting windows.
        </p>

        <div class="mt-3 grid grid-cols-2 gap-3">
          <div>
            <label class="text-xs font-semibold">Audience</label>
            <select id="audienceType" class="mt-1 w-full glass-strong rounded-2xl px-4 py-3 text-sm">
              <option value="students">Students</option>
              <option value="professionals">Professionals</option>
              <option value="creators">Creators</option>
            </select>
          </div>
          <div>
            <label class="text-xs font-semibold">Timezone</label>
            <select id="audienceTZ" class="mt-1 w-full glass-strong rounded-2xl px-4 py-3 text-sm">
              <option value="local" selected>Local Device</option>
              <option value="est">US/Eastern</option>
              <option value="pst">US/Pacific</option>
              <option value="gmt">GMT/UTC</option>
            </select>
          </div>
        </div>

        <div class="mt-3 flex gap-2">
          <button id="btnTime" class="tap press flex-1 rounded-2xl bg-white/20 hover:bg-white/25 px-4 py-3 text-sm font-bold">
            Suggest Best Times
          </button>
          <button id="btnCopyTimes" class="tap press chip rounded-2xl px-4 py-3 text-sm font-semibold">
            Copy
          </button>
        </div>

        <div class="mt-3 glass-strong rounded-2xl p-3">
          <div class="text-xs font-semibold text-white/80">Suggested Times</div>
          <div id="timeOut" class="mt-2 text-sm text-white/90"></div>
        </div>
      </article>

      <!-- 8) Shadowban Safety Check -->
      <article id="toolShadowban" class="glass rounded-2xl p-4">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-sm font-extrabold">8) Shadowban Safety Check</h2>
          <span class="chip rounded-full px-3 py-1 text-[11px] font-semibold">Checklist</span>
        </div>
        <p class="text-xs text-white/80 mt-1">
          Check banned hashtags + a quick safety checklist. (Offline reference list included)
        </p>

        <label class="block mt-3 text-xs font-semibold text-white/90">Paste Hashtags (space or newline separated)</label>
        <textarea id="shadowTags" rows="3"
          class="mt-1 w-full glass-strong rounded-2xl px-4 py-3 text-sm placeholder:text-white/50"
          placeholder="#likeforlike #follow4follow #instagood ..."></textarea>

        <div class="mt-3 flex gap-2">
          <button id="btnShadowCheck" class="tap press flex-1 rounded-2xl bg-white/20 hover:bg-white/25 px-4 py-3 text-sm font-bold">
            Run Safety Check
          </button>
          <button id="btnCopyShadow" class="tap press chip rounded-2xl px-4 py-3 text-sm font-semibold">
            Copy Report
          </button>
        </div>

        <div class="mt-3 glass-strong rounded-2xl p-3">
          <div class="text-xs font-semibold text-white/80">Report</div>
          <div id="shadowOut" class="mt-2 text-sm text-white/90"></div>
        </div>

        <div class="mt-3 glass-strong rounded-2xl p-3">
          <div class="text-xs font-semibold text-white/80">Quick Checklist</div>
          <div class="mt-2 space-y-2 text-sm">
            <label class="flex items-start gap-3 tap">
              <input type="checkbox" class="mt-1" />
              <span class="text-white/90">I’m not using repetitive copy-paste comments.</span>
            </label>
            <label class="flex items-start gap-3 tap">
              <input type="checkbox" class="mt-1" />
              <span class="text-white/90">I avoid engagement pods and bot services.</span>
            </label>
            <label class="flex items-start gap-3 tap">
              <input type="checkbox" class="mt-1" />
              <span class="text-white/90">I vary hashtags and keep them relevant.</span>
            </label>
            <label class="flex items-start gap-3 tap">
              <input type="checkbox" class="mt-1" />
              <span class="text-white/90">I post consistently and don’t spam stories.</span>
            </label>
          </div>
        </div>
      </article>

      <!-- 9) Professional Bio Architect -->
      <article id="toolBio" class="glass rounded-2xl p-4">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-sm font-extrabold">9) Professional Bio Architect</h2>
          <span class="chip rounded-full px-3 py-1 text-[11px] font-semibold">4 lines</span>
        </div>
        <p class="text-xs text-white/80 mt-1">
          Build a clean, icon-based 4-line bio for your niche.
        </p>

        <div class="mt-3 space-y-3">
          <div>
            <label class="text-xs font-semibold">Name / Brand</label>
            <input id="bioName" class="mt-1 w-full glass-strong rounded-2xl px-4 py-3 text-sm" placeholder="Nexovent" />
          </div>
          <div>
            <label class="text-xs font-semibold">What you do</label>
            <input id="bioWhat" class="mt-1 w-full glass-strong rounded-2xl px-4 py-3 text-sm" placeholder="Helping creators grow with strategy + design" />
          </div>
          <div>
            <label class="text-xs font-semibold">Proof / Credibility</label>
            <input id="bioProof" class="mt-1 w-full glass-strong rounded-2xl px-4 py-3 text-sm" placeholder="100+ reels optimized • 1M+ total views" />
          </div>
          <div>
            <label class="text-xs font-semibold">Call-to-action</label>
            <input id="bioCTA" class="mt-1 w-full glass-strong rounded-2xl px-4 py-3 text-sm" placeholder="DM “GROW” for a free audit" />
          </div>
        </div>

        <div class="mt-3 flex gap-2">
          <button id="btnGenBio" class="tap press flex-1 rounded-2xl bg-white/20 hover:bg-white/25 px-4 py-3 text-sm font-bold">
            Generate Bio
          </button>
          <button id="btnCopyBio" class="tap press chip rounded-2xl px-4 py-3 text-sm font-semibold">
            Copy
          </button>
        </div>

        <div class="mt-3 glass-strong rounded-2xl p-3">
          <div class="text-xs font-semibold text-white/80">Bio Output</div>
          <pre id="bioOut" class="mt-2 whitespace-pre-wrap text-sm text-white/90"></pre>
        </div>
      </article>

      <!-- 10) Reel Content Planner -->
      <article id="toolPlanner" class="glass rounded-2xl p-4">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-sm font-extrabold">10) Reel Content Planner</h2>
          <span class="chip rounded-full px-3 py-1 text-[11px] font-semibold">7 days</span>
        </div>
        <p class="text-xs text-white/80 mt-1">
          Generate a 7-day reel schedule. Choose niche and intensity.
        </p>

        <div class="mt-3 grid grid-cols-2 gap-3">
          <div>
            <label class="text-xs font-semibold">Niche</label>
            <select id="planNiche" class="mt-1 w-full glass-strong rounded-2xl px-4 py-3 text-sm">
              <option value="tech">Tech</option>
              <option value="finance">Finance</option>
              <option value="lifestyle">Lifestyle</option>
            </select>
          </div>
          <div>
            <label class="text-xs font-semibold">Intensity</label>
            <select id="planIntensity" class="mt-1 w-full glass-strong rounded-2xl px-4 py-3 text-sm">
              <option value="balanced" selected>Balanced</option>
              <option value="aggressive">Aggressive</option>
              <option value="educational">Educational</option>
            </select>
          </div>
        </div>

        <div class="mt-3 flex gap-2">
          <button id="btnGenPlan" class="tap press flex-1 rounded-2xl bg-white/20 hover:bg-white/25 px-4 py-3 text-sm font-bold">
            Generate 7-Day Plan
          </button>
          <button id="btnCopyPlan" class="tap press chip rounded-2xl px-4 py-3 text-sm font-semibold">
            Copy
          </button>
        </div>

        <div class="mt-3 glass-strong rounded-2xl p-3">
          <div class="text-xs font-semibold text-white/80">Schedule</div>
          <div id="planOut" class="mt-2 text-sm text-white/90 space-y-2"></div>
        </div>
      </article>

    </section>
  </main>

  <!-- Footer -->
  <footer class="fixed bottom-0 left-0 right-0 z-40 safe-bot">
    <div class="mx-auto max-w-md px-4 pb-3">
      <div class="glass rounded-2xl px-4 py-3 flex items-center justify-between gap-3">
