      const s = String(str).trim().toLowerCase().replace(/,/g, "");
      const mult = s.endsWith("k") ? 1e3 : s.endsWith("m") ? 1e6 : s.endsWith("b") ? 1e9 : 1;
      const num = parseFloat(s.replace(/[kmb]$/,""));
      return Number.isFinite(num) ? num * mult : 0;
