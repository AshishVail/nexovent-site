    // ---------- 2) Color Palette Extractor (Canvas quantization) ----------
    function rgbToHex(r,g,b){
      const to = (n) => n.toString(16).padStart(2,"0");
      return `#${to(r)}${to(g)}${to(b)}`.toUpperCase();
    }

    function colorDistance(a,b){
      const dr=a.r-b.r, dg=a.g-b.g, db=a.b-b.b;
      return dr*dr + dg*dg + db*db;
    }

    function extractPaletteFromCanvas(canvas, count = 6) {
      const ctx = canvas.getContext("2d", { willReadFrequently: true });
      const { width, height } = canvas;
      const img = ctx.getImageData(0,0,width,height).data;

      // Sample pixels (skip for speed)
      const samples = [];
      const step = Math.max(1, Math.floor((width * height) / 12000)); // dynamic sampling
      for (let i=0; i<img.length; i += 4 * step) {
        const r = img[i], g = img[i+1], b = img[i+2], a = img[i+3];
        if (a < 200) continue; // ignore transparent
        // ignore near-black/near-white extremes slightly (keeps palette nicer)
        const lum = 0.2126*r + 0.7152*g + 0.0722*b;
        if (lum < 10 || lum > 245) continue;
        samples.push({ r,g,b });
      }
      if (!samples.length) return [];

      // K-means-ish clustering (small iterations)
      const centers = [];
      for (let i=0; i<count; i++) centers.push(samples[Math.floor(Math.random()*samples.length)]);

      for (let iter=0; iter<7; iter++){
        const buckets = Array.from({length: count}, () => ({ r:0,g:0,b:0,n:0 }));
        for (const p of samples){
          let bestI=0, bestD=Infinity;
          for (let i=0; i<count; i++){
            const d = colorDistance(p, centers[i]);
            if (d < bestD){ bestD=d; bestI=i; }
          }
          const b = buckets[bestI];
          b.r += p.r; b.g += p.g; b.b += p.b; b.n++;
        }
        for (let i=0; i<count; i++){
          const b = buckets[i];
          if (b.n > 0){
            centers[i] = { r: Math.round(b.r/b.n), g: Math.round(b.g/b.n), b: Math.round(b.b/b.n) };
          }
        }
      }

      // Sort by "presence" approx by nearest assignments one more time
      const counts = Array(count).fill(0);
      for (const p of samples){
        let bestI=0, bestD=Infinity;
        for (let i=0; i<count; i++){
          const d = colorDistance(p, centers[i]);
          if (d < bestD){ bestD=d; bestI=i; }
        }
        counts[bestI]++;
      }

      const items = centers.map((c,i)=>({ hex: rgbToHex(c.r,c.g,c.b), w: counts[i], rgb:c }));
      items.sort((a,b)=>b.w-a.w);

      // de-duplicate close colors
      const out = [];
      for (const it of items){
        if (!out.some(o => colorDistance(o.rgb, it.rgb) < 600)) out.push(it);
        if (out.length >= count) break;
      }
      return out.map(x => x.hex);
    }

