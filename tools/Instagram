    function shadowbanReport(input) {
      const raw = (input || "").trim();
      const tags = raw
        .split(/\s+/g)
        .map(t => t.trim())
        .filter(Boolean)
        .map(t => t.startsWith("#") ? t : `#${t}`)
        .map(t => t.toLowerCase());

      const unique = Array.from(new Set(tags));
      const banned = unique.filter(t => BANNED_HASHTAGS.has(t));
      const score = clamp(100 - banned.length * 18, 0, 100);

      const lines = [];
      lines.push(`Shadowban Safety Report`);
      lines.push(`• Tags checked: ${unique.length}`);
