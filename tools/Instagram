      const modal = ensureVideoModal();
      const frame = $("#videoFrame", modal);
      frame.src = `https://www.youtube-nocookie.com/embed/${encodeURIComponent(youtubeId)}?autoplay=1&rel=0&modestbranding=1&playsinline=1`;
      modal.classList.remove("hidden");
      document.documentElement.style.overflow = "hidden";
    }

    function closeVideoModal() {
      const modal = $("#videoModal");
      if (!modal) return;
      const frame = $("#videoFrame", modal);
      if (frame) frame.src = "about:blank";
      modal.classList.add("hidden");
      document.documentElement.style.overflow = "";
    }

    // ---------- App wiring ----------
    function mount() {
      // Jump buttons
      document.addEventListener("click", (e) => {
        const btn = e.target.closest("[data-jump]");
        if (!btn) return;
        const sel = btn.getAttribute("data-jump");
        const el = sel ? document.querySelector(sel) : null;
        if (el) el.scrollIntoView({ behavior: "smooth", block: "start" });
      });

      // Help modal
      const helpModal = $("#helpModal");
      $("#btnHelp")?.addEventListener("click", () => helpModal.classList.remove("hidden"));
      $("#btnCloseHelp")?.addEventListener("click", () => helpModal.classList.add("hidden"));
      helpModal?.addEventListener("click", (e) => {
        if (e.target.classList.contains("modal-backdrop")) helpModal.classList.add("hidden");
      });

      // Footer top button
      $("#btnTop")?.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));

      // 1) Script writer
      $("#btnGenScript")?.addEventListener("click", () => {
        const topic = $("#scriptTopic").value;
        $("#scriptOut").textContent = generateReelScript(topic);
      });
      $("#btnCopyScript")?.addEventListener("click", () => copyText($("#scriptOut").textContent || ""));

      // 2) Palette extractor
      const canvas = $("#paletteCanvas");
      const ctx = canvas.getContext("2d", { willReadFrequently: true });

      $("#paletteFile")?.addEventListener("change", async (e) => {
        const file = e.target.files?.[0];
        if (!file) return;

        const img = new Image();
        img.decoding = "async";
        img.loading = "eager";

        img.onload = () => {
          // fit image into canvas (square-ish for better sampling)
          const maxW = 520;
          const scale = Math.min(1, maxW / img.width);
          const w = Math.max(240, Math.round(img.width * scale));
          const h = Math.round(img.height * scale);
          canvas.width = w;
          canvas.height = h;

          ctx.drawImage(img, 0, 0, w, h);

          const palette = extractPaletteFromCanvas(canvas, 6);
          renderPalette(palette);
        };

        img.src = await fileToDataURL(file);
      });

      $("#btnCopyPalette")?.addEventListener("click", () => {
        const hexes = Array.from(document.querySelectorAll("[data-hex]")).map(x => x.getAttribute("data-hex"));
        copyText(hexes.join(", "));
      });

      function renderPalette(hexes) {
        const wrap = $("#paletteSwatches");
        wrap.innerHTML = "";
        if (!hexes.length) {
          wrap.innerHTML = `<div class="text-xs text-white/70 col-span-2">Upload an image to extract colors.</div>`;
          return;
        }
        for (const hex of hexes) {
          const item = document.createElement("button");
          item.className = "tap press glass-strong rounded-2xl p-2 text-left";
          item.setAttribute("data-hex", hex);
          item.innerHTML = `
            <div class="rounded-xl h-12 w-full" style="background:${hex}; border:1px solid rgba(255,255,255,.18)"></div>
            <div class="mt-2 text-xs font-bold">${hex}</div>
          `;
          item.addEventListener("click", () => copyText(hex));
          wrap.appendChild(item);
        }
      }

      function fileToDataURL(file) {
        return new Promise((res, rej) => {
          const r = new FileReader();
          r.onload = () => res(String(r.result));
          r.onerror = rej;
          r.readAsDataURL(file);
        });
      }

      // 3) Font styler
      const fontInput = $("#fontInput");
      const fontList = $("#fontList");

      function renderFonts(text) {
        const t = text || "";
        fontList.innerHTML = "";
        FONT_STYLES.forEach((st, idx) => {
          const val = st.map(t);
          const row = document.createElement("div");
          row.className = "tap press glass-strong rounded-2xl p-3";
          row.innerHTML = `
            <div class="flex items-center justify-between gap-3">
              <div class="min-w-0">
                <div class="text-[11px] text-white/70 font-semibold">${st.name}</div>
                <div class="text-sm font-semibold text-white/95 break-words">${escapeHTML(val) || "<span class='text-white/60'>…</span>"}</div>
              </div>
              <button class="chip rounded-xl px-3 py-2 text-xs font-semibold shrink-0">Copy</button>
            </div>
          `;
          row.querySelector("button").addEventListener("click", () => copyText(val));
          fontList.appendChild(row);
        });
      }

      fontInput?.addEventListener("input", () => renderFonts(fontInput.value));
      $("#btnCopyFirstFont")?.addEventListener("click", () => {
        const t = fontInput.value || "";
        const top = FONT_STYLES[0].map(t);
        copyText(top);
      });
      renderFonts("");

      function escapeHTML(str){
        return String(str)
          .replaceAll("&","&amp;")
          .replaceAll("<","&lt;")
          .replaceAll(">","&gt;")
          .replaceAll('"',"&quot;")
          .replaceAll("'","&#039;");
      }

      // 4) Caption generator
      $("#btnGenCaption")?.addEventListener("click", () => {
        const desc = $("#captionDesc").value;
        $("#captionOut").textContent = generateCaption(desc);
      });
      $("#btnCopyCaption")?.addEventListener("click", () => copyText($("#captionOut").textContent || ""));

      // 5) Hashtag finder
      $("#btnGenTags")?.addEventListener("click", () => {
        const niche = $("#tagNiche").value;
        const total = parseInt($("#tagCount").value, 10);
        const { low, high } = genHashtags(niche, total);
        renderTagChips($("#tagsLow"), low);
        renderTagChips($("#tagsHigh"), high);
      });

      $("#btnCopyTags")?.addEventListener("click", () => {
        const all = [
          ...Array.from($("#tagsLow").querySelectorAll("[data-tag]")).map(x => x.getAttribute("data-tag")),
          ...Array.from($("#tagsHigh").querySelectorAll("[data-tag]")).map(x => x.getAttribute("data-tag"))
        ].filter(Boolean);
        copyText(all.join(" "));
      });

      function renderTagChips(root, tags) {
        root.innerHTML = "";
        tags.forEach(t => {
          const b = document.createElement("button");
          b.className = "tap press chip rounded-full px-3 py-2 text-xs font-semibold";
          b.setAttribute("data-tag", t);
          b.textContent = t;
          b.addEventListener("click", () => copyText(t));
          root.appendChild(b);
        });
      }

      // 6) Engagement calc
      $("#btnCalcER")?.addEventListener("click", () => {
        const followers = parseNumberLike($("#erFollowers").value);
        const likes = parseNumberLike($("#erLikes").value);
        const comments = parseNumberLike($("#erComments").value);

        const { er, score, label } = calcEngagementRate(followers, likes, comments);

        if (followers <= 0) {
          $("#erOut").innerHTML = `<div class="text-white/90">Please enter a valid follower count.</div>`;
          return;
        }

        const badge =
          score >= 80 ? "bg-emerald-400/20 border-emerald-200/25" :
          score >= 55 ? "bg-sky-400/20 border-sky-200/25" :
          score >= 35 ? "bg-amber-400/20 border-amber-200/25" :
                        "bg-rose-400/20 border-rose-200/25";

        $("#erOut").innerHTML = `
          <div class="flex items-center justify-between gap-3">
            <div>
              <div class="text-sm font-bold">Engagement Rate: ${er.toFixed(2)}%</div>
              <div class="text-xs text-white/75">Health: ${label}</div>
            </div>
            <div class="chip ${badge} rounded-2xl px-3 py-2 text-sm font-extrabold border">
              ${score}/100
            </div>
          </div>
          <div class="mt-2 text-xs text-white/80">
            Rule of thumb: <b>3–6%</b> is strong for many accounts. Context matters by niche.
          </div>
        `;
      });

      $("#btnResetER")?.addEventListener("click", () => {
        $("#erFollowers").value = "";
        $("#erLikes").value = "";
        $("#erComments").value = "";
        $("#erOut").textContent = "";
      });

      // 7) Best posting times
      $("#btnTime")?.addEventListener("click", () => {
        const aud = $("#audienceType").value;
        const tz = $("#audienceTZ").value;
        const text = formatTimeSuggestions(aud, tz);
        $("#timeOut").textContent = text;
      });
      $("#btnCopyTimes")?.addEventListener("click", () => copyText($("#timeOut").textContent || ""));

      // 8) Shadowban check
      $("#btnShadowCheck")?.addEventListener("click", () => {
        const report = shadowbanReport($("#shadowTags").value);
        $("#shadowOut").textContent = report;
      });
      $("#btnCopyShadow")?.addEventListener("click", () => copyText($("#shadowOut").textContent || ""));

      // 9) Bio generator
      $("#btnGenBio")?.addEventListener("click", () => {
        const bio = generateBio({
          name: $("#bioName").value,
          what: $("#bioWhat").value,
          proof: $("#bioProof").value,
          cta: $("#bioCTA").value
        });
        $("#bioOut").textContent = bio;
      });
      $("#btnCopyBio")?.addEventListener("click", () => copyText($("#bioOut").textContent || ""));

      // 10) Planner
      $("#btnGenPlan")?.addEventListener("click", () => {
        const niche = $("#planNiche").value;
        const intensity = $("#planIntensity").value;
        const plan = generatePlan(niche, intensity);
        renderPlan(plan);
      });
      $("#btnCopyPlan")?.addEventListener("click", () => {
        const lines = Array.from($("#planOut").querySelectorAll("[data-line]")).map(x => x.getAttribute("data-line"));
        copyText(lines.join("\n"));
      });

      function renderPlan(plan) {
        const out = $("#planOut");
        out.innerHTML = "";
        plan.forEach(p => {
          const row = document.createElement("div");
          row.className = "tap press glass-strong rounded-2xl p-3";
          row.setAttribute("data-line", `${p.day}: ${p.topic}`);
          row.innerHTML = `
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <div class="text-[11px] text-white/70 font-semibold">${p.day}</div>
                <div class="text-sm font-bold text-white/95">${p.topic}</div>
                <div class="text-xs text-white/75 mt-1">Hook → Value → CTA • Add captions • Quick cuts</div>
              </div>
              <button class="chip rounded-xl px-3 py-2 text-xs font-semibold shrink-0">Copy</button>
            </div>
          `;
          row.querySelector("button").addEventListener("click", () => copyText(`${p.day}: ${p.topic}`));
          out.appendChild(row);
        });
      }

      // Video popup delegation (feature ready)
      document.addEventListener("click", (e) => {
        const a = e.target.closest?.('a[data-video="popup"]');
        if (!a) return;
        const id = parseYouTubeId(a.href || "");
        if (!id) return;
        e.preventDefault();
        openVideoModal(id);
      });
    }

    // Fast start
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", mount, { once: true });
    } else {
      mount();
    }
  </script>
</body>
</html>
