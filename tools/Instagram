    function makeMapper(Acap, alow, zero) {
      // Create mapper for A-Z and a-z ranges if they exist in unicode block.
      // Note: Some blocks don't include digits; we keep digits as-is unless provided.
      const capStart = Acap.codePointAt(0);
      const lowStart = alow.codePointAt(0);
      const zeroStart = zero && zero !== "0" ? zero.codePointAt(0) : null;

      return function mapText(s){
        let out = "";
        for (const ch of (s || "")){
          const code = ch.codePointAt(0);
          if (code >= 65 && code <= 90){
            out += String.fromCodePoint(capStart + (code - 65));
          } else if (code >= 97 && code <= 122){
            out += String.fromCodePoint(lowStart + (code - 97));
          } else if (zeroStart && code >= 48 && code <= 57){
            out += String.fromCodePoint(zeroStart + (code - 48));
          } else {
            out += ch;
          }
        }
        return out;
      }
    }

    function smallCapsLike(s){
      const map = {
        a:"ᴀ", b:"ʙ", c:"ᴄ", d:"ᴅ", e:"ᴇ", f:"ғ", g:"ɢ", h:"ʜ", i:"ɪ", j:"ᴊ",
        k:"ᴋ", l:"ʟ", m:"ᴍ", n:"ɴ", o:"ᴏ", p:"ᴘ", q:"ǫ", r:"ʀ", s:"s", t:"ᴛ",
        u:"ᴜ", v:"ᴠ", w:"ᴡ", x:"x", y:"ʏ", z:"ᴢ"
      };
      return (s||"").split("").map(ch=>{
        const low = ch.toLowerCase();
        if (map[low]) return map[low];
        return ch;
      }).join("");
    }

    function bubbleLike(s){
      const map = {
        a:"ⓐ",b:"ⓑ",c:"ⓒ",d:"ⓓ",e:"ⓔ",f:"ⓕ",g:"ⓖ",h:"ⓗ",i:"ⓘ",j:"ⓙ",
